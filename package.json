{
  "name": "@xcelera/cli",
  "description": "CLI for xcelera.dev",
  "version": "1.0.0",
  "author": "",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcelera-dev/cli.git"
  },
  "bugs": {
    "url": "https://github.com/xcelera-dev/cli/issues"
  },
  "keywords": ["actions", "xcelera", "performance", "lighthouse"],
  "exports": {
    ".": "./dist/action.js"
  },
  "bin": {
    "xcelera": "dist/cli.js"
  },
  "files": ["dist", "LICENSE", "NOTICE", "README.md"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "check": "npx @biomejs/biome check && npx tsc --noEmit",
    "format:write": "npx @biomejs/biome format --write",
    "local-action": "npx @github/local-action . src/action.ts .env",
    "package": "npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "vitest",
    "all": "npm run format:write && npm run check && npm run test && npm run coverage && npm run package",
    "check:dist": "bash scripts/check-dist.sh",
    "prepare": "husky",
    "generate-notice": "npx generate-license-file --input package.json --output NOTICE --overwrite"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@types/env-ci": "^3.1.4",
    "env-ci": "^11.2.0",
    "is-network-error": "^1.3.1",
    "parse-github-url": "^1.0.3",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@github/local-action": "^7.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.12.0",
    "husky": "^9.1.7",
    "vitest": "^4.1.0",
    "make-coverage-badge": "^1.2.0",
    "msw": "^2.12.14",
    "rollup": "^4.60.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
